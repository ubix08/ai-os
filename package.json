{
  "name": "ai-os",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:client": "vite",
    "dev:worker": "wrangler dev src/worker/index.ts",
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:worker\"",
    "build:client": "vite build",
    "build:worker": "wrangler deploy --dry-run",
    "build": "npm run build:client && npm run build:worker",
    "deploy": "npm run build:client && wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "zustand": "^5.0.0",
    "react-markdown": "^10.0.0",
    "recharts": "^2.15.0",
    "lucide-react": "^0.546.0",
    "date-fns": "^4.0.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.6.0",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-slot": "^1.2.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.8.0",
    "@cloudflare/workers-types": "^4.20241112.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "tailwindcss": "^4.1.14",
    "@tailwindcss/vite": "^4.1.14",
    "@tailwindcss/typography": "^0.5.19",
    "concurrently": "^9.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0",
    "wrangler": "^3.80.0"
  }
}
